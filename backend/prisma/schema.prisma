generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int    @id @default(autoincrement())
  auth0Id   String @unique
  username  String @db.VarChar(50)
  avatarUrl String?
  coins     Int @default(100)

  createdAt DateTime @default(now())
}

