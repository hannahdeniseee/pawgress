generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id       Int     @id @default(autoincrement())
  auth0Id  String  @unique
  username String?
  coins    Int     @default(100)
  events   Event[]
  tasks    Task[]
}

model Task {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  status    String   @default("uncompleted")
  deadline  DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "Task_userId_fkey")
}

model Event {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  date      DateTime
  time      String?
  venue     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "Event_userId_fkey")
}
