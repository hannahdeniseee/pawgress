generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int    @id @default(autoincrement())
  auth0Id   String @unique
  username  String @db.VarChar(50)
  avatarUrl String?
  coins     Int @default(100)
  inventory UserAccessory[]
  createdAt DateTime @default(now())

  sentRequests     Friendship[] @relation("FriendshipRequester")
  receivedRequests Friendship[] @relation("FriendshipReceiver")
}

model Friendship {
  id          Int      @id @default(autoincrement())
  requesterId Int
  receiverId  Int
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id])
  receiver  User @relation("FriendshipReceiver", fields: [receiverId], references: [id])
}

model Accessory {
  id        Int @id @default(autoincrement())
  name      String @unique
  slot      String
  price     Int
  users     UserAccessory[]
}

model UserAccessory {
  id          Int      @id @default(autoincrement())
  userId      Int
  accessoryId Int
  createdAt   DateTime  @default(now())
  user        User       @relation(fields: [userId], references: [id])
  accessory   Accessory  @relation(fields: [accessoryId], references: [id])

  @@unique([userId, accessoryId])
}